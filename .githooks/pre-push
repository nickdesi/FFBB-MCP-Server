#!/usr/bin/env bash
set -euo pipefail

# Run ruff check on the repository before pushing. Prefer venv binary if present.
if [ -x ".venv/bin/ruff" ]; then
  .venv/bin/ruff check .
elif command -v ruff >/dev/null 2>&1; then
  ruff check .
else
  echo "ruff not found; skipping check. Install ruff in .venv or globally." >&2
fi

# Run pytest on the repository before pushing. Prefer venv binary if present.
if [ -x ".venv/bin/pytest" ]; then
  PYTHONPATH=src .venv/bin/pytest tests/
elif command -v pytest >/dev/null 2>&1; then
  PYTHONPATH=src pytest tests/
else
  echo "pytest not found; skipping check. Install pytest in .venv or globally." >&2
fi
