#!/usr/bin/env bash
set -euo pipefail

# Format code with ruff (prefer venv binary if present)
if [ -x ".venv/bin/ruff" ]; then
  .venv/bin/ruff format --fix . || true
  .venv/bin/ruff check .
elif command -v ruff >/dev/null 2>&1; then
  ruff format --fix . || true
  ruff check .
else
  echo "ruff not found; skipping formatting/check. Install ruff in .venv or globally." >&2
  exit 0
fi

# Stage changes made by the formatter
git add -A
